[Unit]
Description=Cleaning Service Telegram Bot
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/cleaning-bot
EnvironmentFile=/opt/cleaning-bot/.env
ExecStart=/opt/cleaning-bot/venv/bin/python /opt/cleaning-bot/bot.py
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
